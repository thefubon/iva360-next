{
  "name": "iva360",
  "version": "1.0.0",
  "private": true,
  "description": "IVA360 monorepo — web frontend, Payload CMS, shared types",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run.mjs dev",
    "dev:web": "pnpm --filter @iva360/web dev",
    "dev:cms": "pnpm --filter @iva360/cms dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @iva360/web build",
    "build:cms": "pnpm --filter @iva360/cms build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "generate:types": "pnpm --filter @iva360/cms generate:types",
    "generate:importmap": "pnpm --filter @iva360/cms generate:importmap",
    "generate:hugeicons": "node scripts/generate-hugeicons-names.mjs",
    "payload": "pnpm --filter @iva360/cms payload",
    "test:gate": "node scripts/run.mjs test",
    "test:gate:quick": "node scripts/run.mjs test --quick",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:int": "pnpm --filter @iva360/cms test:int",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts; rm -rf playwright-report test-results blob-report 2>/dev/null || true",
    "types:check": "pnpm generate:types && git diff --exit-code packages/shared/src/payload-types.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@vitejs/plugin-react": "4.5.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "turbo": "^2.5.8",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.12.1"
}
