      "default": "./src/i18n.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0 --config ../../eslint.config.mjs"
  },
  "dependencies": {
    "dotenv": "16.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
