# Copy to .env: cp .env.example .env
# Local dev: pnpm dev  (or: bash scripts/dev.sh)
# Production: copy to server and use with docker-compose.prod.yml

# ── Docker (PostgreSQL + MinIO) ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=iva360
POSTGRES_PORT=5432

# ── CMS (apps/cms) ──────────────────────────────────────────────────────────
# Local: 127.0.0.1 | Prod (compose): postgres
DATABASE_URL=postgres://postgres:change-me@127.0.0.1:5432/iva360
PAYLOAD_SECRET=YOUR_SECRET_HERE

S3_BUCKET=iva360-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
# Local: 127.0.0.1:9000 | Prod (compose): http://minio:9000
S3_ENDPOINT=http://127.0.0.1:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Web (apps/web) ──────────────────────────────────────────────────────────
# Server-side fetch to CMS (SSR). Rewrites /admin and /api to this URL.
# Local: http://localhost:3333 | Prod (compose): http://cms:3333
CMS_INTERNAL_URL=http://localhost:3333
# Public CMS URL for client links (optional; same-origin via rewrites if unset)
# Single domain:  https://iva360.ru
# Subdomain:      https://cms.iva360.ru
# Публичный URL сайта (кнопка «Открыть сайт» в админке). Приоритет: CMS_PUBLIC_URL → WEB_PUBLIC_URL → localhost:3000
# WEB_PUBLIC_URL=http://localhost:3000
# CMS_PUBLIC_URL=http://localhost:3000
#
# Live Preview (Payload admin → фронтенд):
# WEB_PUBLIC_URL — URL сайта в iframe предпросмотра (шапка/подвал). Приоритет: CMS_PUBLIC_URL → WEB_PUBLIC_URL → localhost:3000
# PAYLOAD_SERVER_URL — origin админки в браузере для postMessage (не CMS_INTERNAL_URL).
#   Локально с rewrite /admin на :3000: PAYLOAD_SERVER_URL=http://localhost:3000
#   Админка напрямую на :3333: PAYLOAD_SERVER_URL=http://localhost:3333
# WEB_PUBLIC_URL=http://localhost:3000
# PAYLOAD_SERVER_URL=http://localhost:3000

# ── Production / GitLab CI (docker-compose.prod.yml) ────────────────────────
# GitLab Container Registry base (set in CI or on deploy host)
# CI_REGISTRY_IMAGE=registry.gitlab.example.com/group/iva360
# IMAGE_TAG=latest
#
# Optional: HTTP port for nginx in prod compose
# NGINX_HTTP_PORT=80
